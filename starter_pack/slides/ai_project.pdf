% --- SECTION 1: SOFTMAX REGRESSION ---

% 2. Softmax Mathematical Theory
\begin{frame}{Softmax Regression: Mathematical Foundation}
\begin{columns}
\begin{column}{0.5\textwidth}
\textbf{The Linear Mapping:}
\[ \bs = \bw \bx + \bb \]
Where $\bx \in \R^d$, $\bw \in \R^{k \times d}$.
\vspace{0.3cm}
\textbf{The Probabilistic Map:}
\[ P(y=j | \bx) = \frac{\exp(s_j)}{\sum_{\ell=1}^k \exp(s_\ell)} \]
\end{column}
\begin{column}{0.5\textwidth}
\begin{block}{The Objective Function}
We minimize the \textbf{Cross-Entropy Loss}:
\[ \loss = -\frac{1}{n}\sum_{i=1}^n \sum_{j=1}^k Y_{ij} \log(P_{ij}) \]
This is the negative log-likelihood of the Bernoulli/Multinomial distribution.
\end{block}
\end{column}
\end{columns}
\end{frame}

% 3. Softmax: Numerical Stability
\begin{frame}{Implementation Logic: The Log-Sum-Exp Trick}
Direct exponentiation of large scores $\bs$ leads to numerical \texttt{inf} (overflow).
\begin{block}{Stability Formula}
For each sample, we shift scores by their maximum value $M = \max(\bs)$:
\[ p_j = \frac{\exp(s_j - M)}{\sum_{\ell} \exp(s_\ell - M)} \]
\end{block}
\textbf{Gradient of Loss w.r.t Scores:}
\[ \frac{\partial \loss}{\partial \bs} = \bP - \bY \]
This elegant result allows for efficient backpropagation in the linear case.
\end{frame}

