% --- NEW SLIDE: Summary Table ---
\begin{frame}{Summary of Findings}
\begin{table}
\footnotesize
\centering
\begin{tabular}{lll}
\toprule
\textbf{Task Type} & \textbf{Winner} & \textbf{Why?} \\ \midrule
Linear Gaussian & Softmax Regression & Equal performance, simpler model. \\
Non-linear Moons & NN ($m = 32$) & Structural necessity for curved boundaries. \\
Large Benchmark & NN (Adam) & Statistical Acc boost and better calibration. \\
Low-Width Moons & Softmax/Tie & Hidden layers need width to be effective. \\ \bottomrule
\end{tabular}
\end{table}
\vspace{0.4cm}
\begin{block}{Final Verdict}
Representational complexity is only justified when task geometry demands it.
\end{block}
\end{frame}


% --- SECTION 4: TRACK B ---

% 10. Track B: Uncertainty and Entropy
\begin{frame}{Measuring Model Confidence}
A model should not only be accurate but also \textbf{calibrated}.
\begin{block}{Predictive Entropy ($H$)}
\[ H(\bx) = -\sum_{j=1}^k p_j \log p_j \]
$H$ is high when the model is uncertain (e.g., $p = [0.5, 0.5]$) and low when certain.
\end{block}
\textbf{Reliability Analysis:} 
We bin predictions by confidence and check if \textit{Confidence} $\approx$ \textit{Accuracy}.
\end{frame}

% 11. Reliability Results
\begin{frame}{Reliability Diagram Results}
\begin{columns}
\begin{column}{0.5\textwidth}
\centering \includegraphics[width=0.8\textwidth]{reliability_softmax.png} \\ \footnotesize Softmax (Overconfident)
\end{column}
\begin{column}{0.5\textwidth}
\centering \includegraphics[width=0.8\textwidth]{reliability_nn.png} \\ \footnotesize NN (Better Calibrated)
\end{column}
\end{columns}
\vspace{0.2cm}
\begin{itemize}
    \item \textbf{Finding:} The NN is more "honest" about its mistakes.
    \item \textbf{Softmax Error Confidence:} 60.2\%
    \item \textbf{NN Error Confidence:} 54.1\% (Closer to random 50\% on binary tasks)
\end{itemize}
\end{frame}

% 12. Final Verdict
\begin{frame}{Conclusion}
\begin{itemize}
    \item \textbf{Softmax} is superior for simple, high-dimensional linear tasks due to interpretability and speed.
    \item \textbf{Neural Networks} are essential when the decision boundary requires "warping" of the input space.
    \item \textbf{Optimization Matters:} Adam provides the most stable convergence for the NN architecture.
    \item \textbf{Calibration:} Adding a hidden layer improves not just the labels, but the quality of the predicted probabilities.
\end{itemize}
\end{frame}

% --- NEW SLIDE: Limitations ---
\begin{frame}{Limitations}
\begin{itemize}
    \item \textbf{Scale:} Digits is a small dataset; results might vary on ImageNet or larger tasks.
    \item \textbf{Depth:} We only looked at $L = 1$ hidden layer. Deeper networks (CNNs) might reveal different trade-offs.
    \item \textbf{Seeds:} While 5 seeds give a 95\% CI, more seeds (e.g., 30) would improve Gaussian normality assumptions.
\end{itemize}
\end{frame}

