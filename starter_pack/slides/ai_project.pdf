% --- SECTION 2: NEURAL NETWORKS ---

% 5. NN Mathematical Theory
\begin{frame}{Neural Network Architecture: The Hidden Layer}
To break the linear constraint, we introduce a hidden representation $\bh \in \R^m$:
\begin{enumerate}
    \item \textbf{Hidden Projection:} $\mathbf{z_1} = \bw_1 \bx + \bb_1$
    \item \textbf{Non-linear Activation:} $\bh = \tanh(\mathbf{z_1})$
    \item \textbf{Output Projection:} $\bs = \bw_2 \bh + \bb_2$
    \item \textbf{Softmax:} $\bP = \text{Softmax}(\bs)$
\end{enumerate}
\begin{block}{Universal Approximation Theorem}
A single hidden layer with a non-linear activation can approximate any continuous function, provided the width $m$ is sufficient.
\end{block}
\end{frame}

% 6. Optimization Part 1: Backpropagation
\begin{frame}{Optimization: Manual Gradient Descent}
We implemented the chain rule manually for the NumPy engine:
\begin{itemize}
    \item \textbf{Output Layer:} $\delta_2 = \bP - \bY$
    \item \textbf{Weight 2 Gradients:} $\nabla \bw_2 = \delta_2^T \bh$
    \item \textbf{Hidden Layer Error:} $\delta_1 = (\delta_2 \bw_2) \odot (1 - \tanh^2(\mathbf{z_1}))$
    \item \textbf{Weight 1 Gradients:} $\nabla \bw_1 = \delta_1^T \bx$
\end{itemize}
\textbf{The Update Rule:} $\bw \leftarrow \bw - \eta \nabla \bw$
\end{frame}

% 7. Optimization Part 2: Advanced Optimizers
\begin{frame}{Comparing Optimizers: SGD, Momentum, and Adam}
\begin{itemize}
    \item \textbf{SGD:} Standard gradient descent. Often slow and sensitive to learning rate.
    \item \textbf{Momentum:} $v_t = \gamma v_{t-1} + \eta \nabla \loss$. Helps dampen oscillations.
    \item \textbf{Adam:} Adaptive Moment Estimation. Maintains moving averages of gradients ($m_t$) and squared gradients ($v_t$).
\end{itemize}
